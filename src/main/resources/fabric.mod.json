		"main": [
			"com.alfixjanuarivinter.moreendgame.MoreEndgame"
		],
		"client": [
			"com.alfixjanuarivinter.moreendgame.client.MoreEndgameClient"
		],
		"fabric-datagen": [
			"com.alfixjanuarivinter.moreendgame.client.MoreEndgameDataGenerator"
		]
	},
	"mixins": [
