	"authors": [
		"Alfix"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/more-endgame",
		"sources": "https://github.com/Alfix-Januarivinter/MoreEndgame"
	},
	"license": "CC-BY-SA-4.0",
	"icon": "assets/moreendgame/icon.png",
